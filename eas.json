{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.noble-bac-uemoa.tech/api/v1"

        // "EXPO_PUBLIC_API_URL": "http://10.0.2.2:8000/api/v1"
        // "EXPO_PUBLIC_API_URL": "https://copper-railway-spookily.ngrok-free.dev/api/v1"
      }
    },
    "client-test": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://copper-railway-spookily.ngrok-free.dev/api/v1"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.56:8000/api/v1"
      }
    },
    "staging": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.noble-bac-uemoa.tech/api/v1",
        "EXPO_PUBLIC_BYPASS_AUTH": "false",
        "EXPO_PUBLIC_BYPASS_OTP": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.noble-bac-uemoa.tech/api/v1",
        "EXPO_PUBLIC_BYPASS_AUTH": "false",
        "EXPO_PUBLIC_BYPASS_OTP": "false"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "environment": "development"
    }
  },
  "submit": {
    "production": {}
  }
}
